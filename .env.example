# ============================================================================
# ENVIRONMENT CONFIGURATION - Copy to .env and update with your values
# ============================================================================

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
LOG_FORMAT=json

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
TELEGRAM_WEBHOOK_PATH=/api/webhook/telegram

# Database - PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=buildmate_db
DATABASE_USER=buildmate_user
DATABASE_PASSWORD=your_secure_password_here
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_TIMEOUT=5000

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=5000
REDIS_ENABLE_OFFLINE_QUEUE=true

# API Configuration
API_WEBHOOK_SECRET=your_webhook_secret_key_here
API_REQUEST_TIMEOUT=30000
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# Security
SESSION_SECRET=your_session_secret_key_here
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_OUTPUT=console,file
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=14

# AI Service (Optional)
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1
AI_MODEL=gpt-4
AI_REQUEST_TIMEOUT=30000

# External Services (Optional)
GITHUB_TOKEN=
GITLAB_TOKEN=
SLACK_WEBHOOK_URL=

# Feature Flags
FEATURE_ANALYTICS=true
FEATURE_NOTIFICATIONS=true
FEATURE_WEBHOOK=true

# Development
DEBUG=buildmate:*
NODEMON_LEGACY_WATCH=false
