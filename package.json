{
  "name": "buildmate-ai",
  "version": "1.0.0",
  "description": "AI mentor that teaches developers to build software step by step",
  "type": "module",
  "main": "src/index.js",
  "author": "BuildMate Team",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "echo 'Build script for production'",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=text-summary",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\"",
    "db:init": "node scripts/db-init.js",
    "db:migrate": "node scripts/db-migrate.js",
    "db:reset": "node scripts/db-reset.js",
    "docker:build": "docker build -t buildmate-ai:latest .",
    "docker:push": "docker push buildmate-ai:latest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "telegraf": "^4.15.0",
    "pg": "^8.11.3",
    "redis": "^4.6.13",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^8.56.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "@types/jest": "^29.5.11"
  }
}
